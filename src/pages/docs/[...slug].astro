---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
  const nav = docs.map((d) => ({ slug: d.id, title: d.data.title }));
  return docs.map((entry) => ({ params: { slug: entry.id }, props: { entry, nav } }));
}

const { entry, nav } = Astro.props;
const { Content } = await render(entry);
---
<DocsLayout title={entry.data.title} nav={nav} current={entry.id} sourceUrl={entry.data.sourceUrl}>
  <Content />
</DocsLayout>
